def embed_text(text):
    r = requests.post(EMB_URL, headers=headers, json={"inputs": text})
    return r.json()

4. train_fusion_model.py

import numpy as np, pandas as pd, joblib
from sklearn.linear_model import LogisticRegression

df = pd.read_pickle('processed.pkl')
X = np.vstack(df['embedding'].values)
y = df['label'].values

model = LogisticRegression(max_iter=1000, class_weight='balanced')
model.fit(X, y)

joblib.dump(model, 'fusion_model.joblib')
print("Model saved.")

5. score.py (Azure Real-Time Endpoint)

import json, numpy as np, joblib, os

def init():
    global model
    path = os.environ['AZUREML_MODEL_DIR']
    model = joblib.load(os.path.join(path, 'fusion_model.joblib'))

def run(raw):
    d = json.loads(raw)
    emb = np.array(d['embedding'])
    p = float(model.predict_proba([emb])[0][1])
    return {'score': p}

