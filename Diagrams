import spacy
from typing import Iterable
import pandas as pd

NLP = spacy.load("en_core_web_sm")
ENT_LABELS = {"PERSON", "GPE", "LOC", "ORG", "NORP"}  # adjust as needed

def mask_text_spacy(text: str) -> str:
    if not text:
        return text
    doc = NLP(text)
    out = text
    # Replace entities from end to start to keep character offsets valid
    for ent in sorted(doc.ents, key=lambda e: e.start_char, reverse=True):
        if ent.label_ in ENT_LABELS:
            out = out[:ent.start_char] + f"[{ent.label_}]" + out[ent.end_char:]
    return out

def mask_dataframe_spacy(df: pd.DataFrame, text_cols: Iterable[str]) -> pd.DataFrame:
    df = df.copy()
    for col in text_cols:
        df[col] = df[col].fillna('').astype(str).map(mask_text_spacy)
    return df

