import json, numpy as np, joblib, os

def init():
    global model, scaler
    model = joblib.load(os.path.join(os.environ["AZUREML_MODEL_DIR"], "fusion_model.joblib"))
    scaler = joblib.load(os.path.join(os.environ["AZUREML_MODEL_DIR"], "tab_scaler.joblib"))

def run(raw):
