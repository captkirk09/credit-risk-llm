import os, json, joblib, numpy as np

REQUIRED_NUMERIC = ("loan_amnt", "annual_inc", "dti", "revol_util")

def _validate_payload(d: dict):
    # Basic checks
    for k in REQUIRED_NUMERIC:
        if k not in d:
            raise ValueError(f"Missing numeric field: '{k}'")
        if not isinstance(d[k], (int, float)):
            raise TypeError(f"Field '{k}' must be a number (int/float), got {type(d[k])}")

    if "desc_embedding" not in d:
        raise ValueError("Missing 'desc_embedding' array")

    emb = d["desc_embedding"]
    if not isinstance(emb, (list, tuple)):
        raise TypeError("'desc_embedding' must be a list of floats")

    if len(emb) < 10:
        raise ValueError("Embedding vector too short; expected >= 10 dimensions")

    # Optional sanity bounds (adjust as appropriate)
    if d["loan_amnt"] <= 0:
        raise ValueError("'loan_amnt' must be > 0")
    if d["annual_inc"] <= 0:
        raise ValueError("'annual_inc' must be > 0")

def init():
    global model, scaler
    model_dir = os.getenv("AZUREML_MODEL_DIR", ".")
    artifacts_dir = os.path.join(model_dir, "artifacts")

    model = joblib.load(os.path.join(artifacts_dir, "fusion_model.joblib"))
    scaler = joblib.load(os.path.join(artifacts_dir, "tab_scaler.joblib"))

def run(raw_data):
    try:
        data = json.loads(raw_data)
        _validate_payload(data)

        tab = np.array([[data["loan_amnt"], data["annual_inc"], data["dti"], data["revol_util"]]], dtype=float)
        tab = scaler.transform(tab)

        emb = np.array([data["desc_embedding"]], dtype=float)
        X = np.hstack([tab, emb])

        prob = float(model.predict_proba(X)[0, 1])
        decision = "High Risk" if prob >= 0.5 else "Low Risk"

        return {"risk_score": prob, "decision": decision}

    except Exception as ex:
        # AML surfaces this back in the response body for debugging
        return {"error": str(ex)}

