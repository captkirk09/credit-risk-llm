from fastapi import FastAPI
from pydantic import BaseModel
import numpy as np
import joblib

# Load model + encoder
model = joblib.load("fusion_model.joblib")
label_encoder = joblib.load("label_encoder.joblib")

api = FastAPI(title="Credit Risk Realtime Scoring API")

# Input schema
class EmbeddingPayload(BaseModel):
    embedding: list

@api.get("/")
def health():
    return {"status": "ok", "message": "Credit risk model is running."}

@api.post("/score")
def score(payload: EmbeddingPayload):
    emb = np.array(payload.embedding).reshape(1, -1)
    
    pred_id = model.predict(emb)[0]
    score = float(model.predict_proba(emb)[0].max())
    pred_label = label_encoder.inverse_transform([pred_id])[0]

    return {
        "predicted_class": pred_label,
        "score": score
    }

