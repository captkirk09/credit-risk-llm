import json, numpy as np, joblib, os

def init():
    global model, scaler
    path = os.environ["AZUREML_MODEL_DIR"]
    model = joblib.load(path + "/fusion_model.joblib")
    scaler = joblib.load(path + "/tab_scaler.joblib")

def run(raw):
    d = json.loads(raw)
    tab = scaler.transform([[d["loan_amnt"], d["annual_inc"], d["dti"], d["revol_util"]]])
    emb = np.array([d["embedding"]])
    X = np.hstack([tab, emb])
    p = float(model.predict_proba(X)[0,1])
    return {"risk_score": p, "decision": "High Risk" if p >= 0.5 else "Low Risk"}

