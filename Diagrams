import json
import numpy as np
import os
import joblib

def init():
    global model, le
    model = joblib.load("fusion_model.joblib")
    le = joblib.load("label_encoder.joblib")

def run(data):
    body = json.loads(data)
    embedding = np.array(body["embedding"]).reshape(1, -1)

    pred = model.predict(embedding)[0]
    prob = float(model.predict_proba(embedding)[0].max())
    label = le.inverse_transform([pred])[0]

    return {
        "predicted_class": label,
        "score": prob
    }

