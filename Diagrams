import json
import numpy as np
import joblib
import os

def init():
    global model
    path = os.environ["AZUREML_MODEL_DIR"]
    model = joblib.load(path + "/fusion_model.joblib")

def run(raw):
    d = json.loads(raw)
    emb = np.array(d["embedding"])
    score = float(model.predict_proba([emb])[0][1])
    return {"score": score}

