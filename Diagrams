# file: utils_pii.py
import re
from typing import Iterable
import pandas as pd

EMAIL = re.compile(r'\b[\w\.-]+@[\w\.-]+\.\w+\b')
PHONE = re.compile(r'\b(?:\+?\d{1,3}[-.\s]?)?(?:\(?\d{2,4}\)?[-.\s]?){2,4}\d{2,4}\b')
LONG_NUM = re.compile(r'\b\d{10,16}\b')  # generic long numbers (IDs, acct numbers)

def mask_text_regex(text: str) -> str:
    if not text:
        return text
    text = EMAIL.sub('[EMAIL]', text)
    text = PHONE.sub('[PHONE]', text)
    text = LONG_NUM.sub('[NUMBER]', text)
    return text

def mask_dataframe(df: pd.DataFrame, text_cols: Iterable[str]) -> pd.DataFrame:
    df = df.copy()
    for col in text_cols:
        df[col] = df[col].fillna('').astype(str).map(mask_text_regex)
    return df

