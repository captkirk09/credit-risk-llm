import re

def simple_pii_mask(text: str):
    text = re.sub(r'\b[\w\.-]+@[\w\.-]+\.\w+\b', '[EMAIL]', text)        # emails
    text = re.sub(r'\b\d{10,16}\b', '[NUMBER]', text)                    # long numbers
    text = re.sub(r'\b(?:\+?\d{1,3}[-.\s]?)?(?:\(?\d{2,4}\)?[-.\s]?){2,4}\d{2,4}\b', '[PHONE]', text) # phones
    return text

df[TEXT_COL] = df[TEXT_COL].apply(simple_pii_mask)

