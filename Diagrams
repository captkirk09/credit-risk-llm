import json
import numpy as np
import joblib
import os

def init():
    global model, label_encoder
    path = os.environ['AZUREML_MODEL_DIR']
    model = joblib.load(os.path.join(path, "fusion_model.joblib"))
    label_encoder = joblib.load(os.path.join(path, "label_encoder.joblib"))

def run(raw_data):
    data = json.loads(raw_data)
    emb = np.array(data["embedding"])
    pred_id = model.predict([emb])[0]
    pred_label = label_encoder.inverse_transform([pred_id])[0]

    return {
        "score_raw": float(model.predict_proba([emb])[0].max()),
        "predicted_class": pred_label
    }

