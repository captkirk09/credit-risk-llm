import requests, time, json

HF_TOKEN = "YOUR_HF_TOKEN"
EMB_URL = "https://api-inference.huggingface.co/pipeline/feature-extraction/sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
headers = {"Authorization": f"Bearer {HF_TOKEN}"}

def embed_text(text):
    # handle None / empty text
    if text is None or len(str(text).strip()) == 0:
        return None

    for attempt in range(5):
        try:
            response = requests.post(
                EMB_URL,
                headers=headers,
                json={"inputs": text}
            )

            # Check if HF returned JSON
            try:
                data = response.json()
            except json.JSONDecodeError:
                print("HF returned non-JSON:", response.text[:200])
                time.sleep(2)
                continue

            # If HF error in response
            if isinstance(data, dict) and "error" in data:
                print("HF API error:", data)
                time.sleep(3)
                continue

            # Expected output is a list of embeddings
            if isinstance(data, list):
                return data

            print("Unexpected HF output:", data)
            time.sleep(2)

        except Exception as e:
            print("Embed error:", e)
            time.sleep(2)

    # If all retries fail:
    return None
