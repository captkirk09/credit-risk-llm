df_model['emb_len'] = df_model['embedding'].apply(lambda x: len(x) if isinstance(x, list) else None)
df_model['emb_len'].value_counts()

df_clean = df_model[df_model["embedding"].apply(lambda x: isinstance(x, list) and len(x) == 3072)]
