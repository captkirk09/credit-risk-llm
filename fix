from tqdm import tqdm
import time

# Initialize column
df["ocr_text"] = df.get("ocr_text", None)

# Budget controls
COST = 0.005          # price per OCR call
MAX  = 8.0            # max spend
spent = 0.0
count = 0

print(f"Starting OCR with max budget = {MAX} USD")

for i in tqdm(range(len(df)), desc="OCR processing"):
    
    # Skip already-processed rows
    if isinstance(df.loc[i, "ocr_text"], str) and len(df.loc[i, "ocr_text"]) > 0:
        continue
    
    # Enforce budget limit
    if spent + COST > MAX:
        print("Budget limit reached — stopping OCR.")
        break

    try:
        # Run OCR on the base64 image
        txt = gpt4o_vision_ocr(df.loc[i, "image"])
        df.loc[i, "ocr_text"] = txt

        # Update cost counters
        spent += COST
        count += 1

    except Exception as e:
        print(f"OCR failed for index {i}: {e}")
        time.sleep(1)

print(f"OCR complete → {count} pages processed, total spent: {spent:.3f} USD")

df.to_pickle("ocr_en_es.pkl")
