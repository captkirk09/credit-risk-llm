2. azure_ocr.py

from azure.ai.vision.imageanalysis import ImageAnalysisClient
from azure.ai.vision.imageanalysis.models import VisualFeatures
from azure.core.credentials import AzureKeyCredential
import base64

VISION_KEY = "<AZURE_OCR_KEY>"
VISION_ENDPOINT = "<AZURE_OCR_ENDPOINT>"

client = ImageAnalysisClient(
    endpoint=VISION_ENDPOINT,
    credential=AzureKeyCredential(VISION_KEY)
)

def azure_ocr(base64_str):
    img_bytes = base64.b64decode(base64_str)
    result = client.analyze(
        image_data=img_bytes,
        visual_features=[VisualFeatures.READ]
    )

    text = ""
    for block in result.read.blocks:
        text += block.text + "
"
    return text

3. generate_embeddings.py

import requests
HF_TOKEN = "YOUR_HF_TOKEN"

EMB_URL = "https://api-inference.huggingface.co/pipeline/feature-extraction/sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
headers = {"Authorization": f"Bearer {HF_TOKEN}"}

def embed_text(text):
    r = requests.post(EMB_URL, headers=headers, json={"inputs": text})
    return r.json()   # returns 768-dimensional embedding

4. process_dataset.py

from tqdm import tqdm
import pandas as pd
from azure_ocr import azure_ocr
from generate_embeddings import embed_text

# Load dataset
df = pd.read_parquet("train-00000.parquet")

# Run OCR
df["ocr_text"] = [azure_ocr(x) for x in tqdm(df["image"])]

# Create embeddings
df["embedding"] = df["ocr_text"].apply(embed_text)

# Save
df.to_pickle("processed.pkl")

