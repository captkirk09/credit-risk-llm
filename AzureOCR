6. score.py

import json, numpy as np, joblib, os

def init():
    global model
    path = os.environ['AZUREML_MODEL_DIR']
    model = joblib.load(os.path.join(path, 'fusion_model.joblib'))

def run(raw):
    d = json.loads(raw)
    emb = np.array(d['embedding'])
    p = float(model.predict_proba([emb])[0][1])
    return {'score': p}

