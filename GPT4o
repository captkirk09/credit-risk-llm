2. gpt4o_vision_ocr.py

from openai import OpenAI
client = OpenAI(api_key="OPENAI_API_KEY")

def gpt4o_vision_ocr(base64_str):
    response = client.chat.completions.create(
        model="gpt-4o-mini",
        messages=[
            {
                "role": "user",
                "content": [
                    {"type": "input_text", "text": "Extract ONLY the text from this image."},
                    {"type": "input_image", "image_url": f"data:image/png;base64,{base64_str}"}
                ]
            }
        ]
    )
    return response.choices[0].message.content

