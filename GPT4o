4. generate_embeddings.py

import requests
HF_TOKEN = "YOUR_HF_TOKEN"

EMB_URL = "https://api-inference.huggingface.co/pipeline/feature-extraction/"
EMB_URL += "sentence-transformers/paraphrase-multilingual-mpnet-base-v2"
headers = {"Authorization": f"Bearer {HF_TOKEN}"}

def embed_text(text):
    r = requests.post(EMB_URL, headers=headers, json={"inputs": text})
    return r.json()  # 768‑dimension embedding

