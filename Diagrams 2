import numpy as np
import pandas as pd
import joblib
from tqdm import tqdm
import matplotlib.pyplot as plt
import shap
from lime.lime_tabular import LimeTabularExplainer
from sklearn.metrics import f1_score, confusion_matrix
import seaborn as sns

# --------------------------
# LOAD DATA AND MODEL
# --------------------------

df = pd.read_pickle("MultiFinBen_EN_ES_ready.pkl")
model = joblib.load("fusion_model.joblib")
le = joblib.load("label_encoder.joblib")

# Keep only valid embeddings
df_clean = df[df["embedding"].apply(lambda x: isinstance(x, list))].reset_index(drop=True)

X = np.vstack(df_clean["embedding"])
y = le.transform(df_clean["label"])

print("Dataset shape:", X.shape)
print("Labels shape:", y.shape)



# Select a small background subset for SHAP
background_size = 50
background = X[:background_size]

# Create SHAP explainer
explainer = shap.KernelExplainer(model.predict_proba, background)




# Explain one sample
sample_idx = 0
shap_values = explainer.shap_values(X[sample_idx:sample_idx+1])

print("Computed SHAP for label classes:", len(shap_values))




# Visualise importance across all embedding dimensions
plt.title("SHAP Summary Plot (Single Instance)")
shap.summary_plot(shap_values, X[sample_idx:sample_idx+1])




plt.title("SHAP Bar Plot (Feature Importance)")
shap.summary_plot(shap_values, X[sample_idx:sample_idx+1], plot_type="bar")



# Prepare LIME explainer
explainer_lime = LimeTabularExplainer(
    training_data=X[:200],             # local neighbourhood
    feature_names=[f"f{i}" for i in range(X.shape[1])],
    class_names=list(le.classes_),
    discretize_continuous=True
)

print("LIME explainer ready.")



instance_idx = 0
exp = explainer_lime.explain_instance(
    X[instance_idx],
    model.predict_proba,
    num_features=12
)

exp.show_in_notebook()




fig = exp.as_pyplot_figure()
plt.title("LIME Explanation for Sample Instance")
fig.savefig("lime_explanation_instance.png", dpi=300)
plt.show()





